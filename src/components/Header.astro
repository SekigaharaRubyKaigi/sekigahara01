---
import { Image } from 'astro:assets';
import logoImage from '../assets/main-visual.svg';
import xLogo from '../assets/x-logo-circle.svg';
import noteLogo from '../assets/note-logo.svg';

/* ▼ メニューを一時的に非表示（コメントアウト）
const navItems = [
  { href: '/about', label: '開催概要' },
  { href: '/schedule', label: 'タイムテーブル' },
  { href: '/speakers', label: 'スピーカー' },
  { href: '/sponsors', label: 'スポンサー' },
];
*/

// パスの取得
const pathname = Astro.url.pathname;
const isTopPage = pathname === '/' || pathname === '/sekigahara01/' || pathname === '/sekigahara01';

const navItems = [
  { href: '/sekigahara01/schedule', label: 'スケジュール', bushoLabel: '軍議次第' },
  { href: '/sekigahara01/events', label: 'イベント', bushoLabel: '陣中催事' },
  { href: '/sekigahara01/busho', label: '武将', bushoLabel: '武将' },
  { href: '/sekigahara01/news', label: 'お知らせ', bushoLabel: '陣触' },
  { href: '/sekigahara01/sponsors', label: 'スポンサー', bushoLabel: '御支援衆' },
  { href: '/sekigahara01/jobboard', label: 'ジョブボード', bushoLabel: '仕官札場' },
  { href: '/sekigahara01/daimyo', label: '大名', bushoLabel: '大名' },
  { href: '/sekigahara01/team', label: 'チーム', bushoLabel: '奉行衆' },
  { href: '/sekigahara01/policies', label: 'ポリシー', bushoLabel: '掟書' },
  { href: '/sekigahara01/goodies', label: 'グッズ', bushoLabel: '陣中土産' },
  { href: '/sekigahara01/access', label: 'アクセス', bushoLabel: '陣所案内' },
];
---

<header class="relative p-4 w-full max-w-screen-xl mx-auto">
  
  <div class="flex items-center justify-between">
    
    <a href="/sekigahara01/" class={`flex items-center no-underline hover:opacity-70 transition-opacity z-50 relative ${isTopPage ? 'opacity-0 pointer-events-none' : ''}`}>
      <img
        src="/sekigahara01/logo.svg"
        alt="関ケ原Ruby会議01 ロゴ"
        class="h-8 w-auto object-contain"
      />
    </a>

    <div class="flex items-center gap-2 lg:gap-4 xl:gap-6 z-50">
      {navItems.map((item) => (
        <a href={item.href} class="nav-link hidden lg:block font-bold text-[#332F2E] hover:bg-[#ddbd58]/50 transition-colors no-underline text-[0.875rem] px-2 py-2 rounded-xl -mx-2">
          <span data-busho-ja={item.label} data-busho-bu={item.bushoLabel}>{item.label}</span>
        </a>
      ))}

      <div class="hidden lg:flex items-center gap-5">
        <a href="https://x.com/sekigahara01" target="_blank" rel="noopener noreferrer" class="hover:opacity-70 transition-opacity no-underline">
          <Image
            src={xLogo}
            alt="X"
            class="w-7 h-7 object-contain"
          />
        </a>

        <a href="https://note.com/sekigahara01" target="_blank" rel="noopener noreferrer" class="hover:opacity-70 transition-opacity no-underline">
          <Image
            src={noteLogo}
            alt="note"
            class="w-7 h-7 object-contain"
          />
        </a>
      </div>

      <button id="menu-btn" class="block lg:hidden focus:outline-none">
        <div class="space-y-2">
          <span class="block w-8 h-0.5 bg-[#332F2E] animate-pulse"></span>
          <span class="block w-8 h-0.5 bg-[#332F2E] animate-pulse"></span>
          <span class="block w-8 h-0.5 bg-[#332F2E] animate-pulse"></span>
        </div>
      </button>
    </div>

  </div>

  <nav id="mobile-menu" class="hidden absolute top-0 left-0 w-full bg-[#C8B66C] shadow-lg z-40 p-4 pt-20 pb-10 border-b-4 border-[#332F2E]">
    <ul class="flex flex-col gap-6 text-center font-bold text-xl text-[#332F2E] mb-8">
      {navItems.map((item) => (
        <li>
          <a href={item.href} class="nav-link block py-2 hover:bg-white/30 rounded transition-colors no-underline">
            <span data-busho-ja={item.label} data-busho-bu={item.bushoLabel}>{item.label}</span>
          </a>
        </li>
      ))}
    </ul>

    <div class="flex justify-center gap-6">
      <a href="https://x.com/sekigahara01" target="_blank" rel="noopener noreferrer" class="hover:opacity-70 transition-opacity no-underline">
        <Image
          src={xLogo}
          alt="X"
          class="w-11 h-11 object-contain"
        />
      </a>
      <a href="https://note.com/sekigahara01" target="_blank" rel="noopener noreferrer" class="hover:opacity-70 transition-opacity no-underline">
        <Image
          src={noteLogo}
          alt="note"
          class="w-11 h-11 object-contain"
        />
      </a>
    </div>
  </nav>

</header>

<script>
  const menuBtn = document.getElementById('menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  if (menuBtn && mobileMenu) {
    menuBtn.addEventListener('click', () => {
      mobileMenu.classList.toggle('hidden');
    });
  }
</script>
