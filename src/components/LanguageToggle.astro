---
---

<div
  class="language-toggle no-underline"
  data-language-toggle
  role="group"
  aria-label="表示する言葉を切り替える"
>
  <button
    type="button"
    class="language-toggle__button"
    data-language-mode-button="ja"
    aria-pressed="true"
  >
    日
  </button>
  <button
    type="button"
    class="language-toggle__button"
    data-language-mode-button="bu"
    aria-pressed="false"
  >
    武
  </button>
</div>

<script is:inline>
  (() => {
    if (window.__sekigaharaLanguageToggleInitialized) return;

    window.__sekigaharaLanguageToggleInitialized = true;

    const storageKey = 'sekigahara-language-mode';
    const modes = new Set(['ja', 'bu']);

    const readMode = () => {
      try {
        const storedMode = window.localStorage.getItem(storageKey);
        return modes.has(storedMode) ? storedMode : 'ja';
      } catch {
        return 'ja';
      }
    };

    const persistMode = (mode) => {
      try {
        window.localStorage.setItem(storageKey, mode);
      } catch {
        // localStorage may be unavailable in private or restricted contexts.
      }
    };

    const updateTexts = (mode) => {
      document.querySelectorAll('[data-busho-ja][data-busho-bu]').forEach((element) => {
        const nextText = mode === 'bu'
          ? element.getAttribute('data-busho-bu')
          : element.getAttribute('data-busho-ja');

        if (nextText !== null) {
          element.textContent = nextText;
        }
      });
    };

    const updateButtons = (mode) => {
      document.querySelectorAll('[data-language-mode-button]').forEach((button) => {
        const isSelected = button.getAttribute('data-language-mode-button') === mode;
        button.setAttribute('aria-pressed', String(isSelected));
      });
    };

    const setMode = (mode, shouldPersist = true) => {
      const nextMode = modes.has(mode) ? mode : 'ja';
      document.documentElement.setAttribute('data-language-mode', nextMode);
      updateTexts(nextMode);
      updateButtons(nextMode);

      if (shouldPersist) {
        persistMode(nextMode);
      }
    };

    const bindToggleButtons = () => {
      document.querySelectorAll('[data-language-mode-button]').forEach((button) => {
        button.addEventListener('click', () => {
          setMode(button.getAttribute('data-language-mode-button'));
        });
      });
    };

    const init = () => {
      bindToggleButtons();
      setMode(readMode(), false);
    };

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', init, { once: true });
      return;
    }

    init();
  })();
</script>

<style>
  .language-toggle {
    align-items: center;
    background: rgba(255, 255, 255, 0.86);
    border: 2px solid #332f2e;
    border-radius: 24px;
    display: inline-flex;
    min-height: 44px;
    overflow: hidden;
  }

  .language-toggle__button {
    -webkit-appearance: none;
    -webkit-tap-highlight-color: transparent;
    align-items: center;
    align-self: stretch;
    appearance: none;
    background: transparent;
    border: none;
    color: #332f2e;
    cursor: pointer;
    display: inline-flex;
    font-weight: 700;
    justify-content: center;
    line-height: 1;
    min-height: 40px;
    min-width: 44px;
    outline: none;
    padding: 0 16px;
    transition:
      background-color 0.2s ease,
      color 0.2s ease,
      opacity 0.2s ease;
  }

  .language-toggle__button:hover {
    opacity: 0.72;
  }

  .language-toggle__button:focus-visible {
    outline: 3px solid #ffffff;
    outline-offset: 2px;
  }

  .language-toggle__button:first-child {
    margin: -2px 0 -2px -2px;
  }

  .language-toggle__button:last-child {
    margin: -2px -2px -2px 0;
  }

  .language-toggle__button[aria-pressed='true'] {
    background: #332f2e;
    color: #ffffff;
  }

</style>
