---
import { Image } from 'astro:assets';
import githubLogo from '../assets/github-logo.svg';
import xLogo from '../assets/x-logo.svg';

interface Props {
  name: string;
  bushoName?: string;
  role?: string;
  bushoRole?: string;
  md5Email?: string;
  sha256Email?: string;
  imageUrl?: string;
  githubID?: string;
  xID?: string;
  website?: string;
}

const { name, bushoName, role, bushoRole, md5Email, sha256Email, imageUrl, githubID, xID, website } = Astro.props;

// 画像URL (ローカル画像またはGravatar)
const avatarUrl = imageUrl
  ? imageUrl
  : md5Email
  ? `https://www.gravatar.com/avatar/${md5Email}?s=400&d=mp`
  : sha256Email
  ? `https://www.gravatar.com/avatar/${sha256Email}?s=400&d=mp`
  : null;
---

<div class="member-profile flex flex-col items-start bg-white/60 p-6 md:p-8 rounded-xl shadow-sm">
  {avatarUrl && (
    <div class="w-32 h-32 md:w-40 md:h-40 mb-2 self-center overflow-hidden rounded-2xl border border-gray-200">
      <img
        src={avatarUrl}
        alt={name}
        class="w-full h-full object-cover"
      />
    </div>
  )}
  {role && (
    <p
      class="text-sm text-[#332F2E] mb-1"
      data-busho-ja={role}
      data-busho-bu={bushoRole ?? role}
    >
      {role}
    </p>
  )}
  <h3
    class="text-xl font-bold leading-snug break-words text-[#332F2E] mb-2"
    data-busho-ja={name}
    data-busho-bu={bushoName ?? name}
  >
    {name}
  </h3>

    {(githubID || xID || website) && (
      <div class="flex flex-col gap-2">
        {(githubID || xID) && (
          <div class="flex gap-4 items-center">
            {githubID && (
              <a
                href={`https://github.com/${githubID}`}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:opacity-70 transition-opacity"
                aria-label={`${name}'s GitHub`}
              >
                <Image src={githubLogo} alt="GitHub" class="w-6 h-6" />
              </a>
            )}

            {xID && (
              <a
                href={`https://x.com/${xID}`}
                target="_blank"
                rel="noopener noreferrer"
                class="hover:opacity-70 transition-opacity"
                aria-label={`${name}'s X (Twitter)`}
              >
                <Image src={xLogo} alt="X" class="w-6 h-6" />
              </a>
            )}
          </div>
        )}
        {xID && (
          <a
            href={`https://x.com/${xID}`}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-[#332F2E] hover:opacity-70 transition-opacity underline"
          >
            @{xID}
          </a>
        )}
        {website && (
          <a
            href={website}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm text-[#332F2E] hover:opacity-70 transition-opacity underline"
          >
            {website}
          </a>
        )}
      </div>
    )}
</div>
