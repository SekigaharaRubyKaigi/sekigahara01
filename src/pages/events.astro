---
import Layout from '../layouts/Layout.astro';
import BushoText from '../components/BushoText.astro';
import LanguageToggle from '../components/LanguageToggle.astro';
import { parse } from 'yaml';
import fs from 'fs';
import path from 'path';

// イベントYAMLを読み込む
const eventsPath = path.join(process.cwd(), 'src', 'content', 'events.yml');
let days = [];

try {
  const eventsContent = fs.readFileSync(eventsPath, 'utf-8');
  const eventsData = parse(eventsContent);
  days = eventsData.days || [];
} catch (e) {
  // ファイルがない場合は空配列
}
---

<Layout title="イベント - 関ケ原Ruby会議01" alignTop={true}>
  <div class="w-full py-10">
    <div class="max-w-screen-lg mx-auto">
      <div class="bg-white/90 px-4 py-8 md:px-8 md:py-16 lg:px-16 rounded-xl shadow-lg">
        <div class="mb-12">
          <BushoText
            as="h1"
            class="text-3xl md:text-4xl font-bold text-center text-[#332F2E] tracking-wider"
            ja="イベント"
            bu="陣中催事"
          />
          <div class="h-2 w-16 mx-auto mt-4 bg-gradient-to-r from-[#fc2158] to-[#0e0aca]"></div>
        </div>

        <div class="mb-8 flex justify-center">
          <LanguageToggle />
        </div>

        <div class="day-nav">
          {days.map((day, index) => (
            <>
              <a
                href={`#${day.id}`}
                class="day-nav-link"
                data-busho-ja={day.label}
                data-busho-bu={day.bushoLabel ?? day.label}
              >
                {day.label}
              </a>
              {index < days.length - 1 && <span class="day-nav-separator">|</span>}
            </>
          ))}
        </div>

        {days.length > 0 ? (
          <div class="days-container">
            {days.map((day) => (
              <div class="day-section" id={day.id}>
                <div class="day-header">
                  <span
                    class="day-label"
                    data-busho-ja={day.label}
                    data-busho-bu={day.bushoLabel ?? day.label}
                  >
                    {day.label}
                  </span>
                  <span
                    class="day-date"
                    data-busho-ja={day.date}
                    data-busho-bu={day.bushoDate ?? day.date}
                  >
                    {day.date}
                  </span>
                </div>

                {day.events && day.events.length > 0 ? (
                  <div class="day-card">
                    <div class="events-list">
                      {day.events.map((event) => (
                        <div class="event-card">
                          <div class="event-thumbnail">
                            <img src={event.thumbnail} alt={event.title} />
                          </div>

                          <div class="event-info">
                            <h2
                              class="event-title"
                              data-busho-ja={event.title}
                              data-busho-bu={event.bushoTitle ?? event.title}
                            >
                              {event.title}
                            </h2>
                            <p
                              class="event-organizer"
                              data-busho-ja={event.organizer}
                              data-busho-bu={event.bushoOrganizer ?? event.organizer}
                            >
                              {event.organizer}
                            </p>

                            {event.description && (
                              <p
                                class="event-description"
                                data-busho-ja={event.description}
                                data-busho-bu={event.bushoDescription ?? event.description}
                              >
                                {event.description}
                              </p>
                            )}

                            <div class="event-details">
                              <div class="detail-row">
                                <span class="detail-label" data-busho-ja="時間" data-busho-bu="刻限">時間</span>
                                <span
                                  class="detail-value"
                                  data-busho-ja={event.time}
                                  data-busho-bu={event.bushoTime ?? event.time}
                                >
                                  {event.time}
                                </span>
                              </div>
                              <div class="detail-row">
                                <span class="detail-label" data-busho-ja="参加費" data-busho-bu="兵糧料">参加費</span>
                                <span
                                  class="detail-value"
                                  data-busho-ja={event.price}
                                  data-busho-bu={event.bushoPrice ?? event.price}
                                >
                                  {event.price}
                                </span>
                              </div>
                              {event.capacity && (
                                <div class="detail-row">
                                  <span class="detail-label" data-busho-ja="定員" data-busho-bu="兵数">定員</span>
                                  <span
                                    class="detail-value"
                                    data-busho-ja={event.capacity}
                                    data-busho-bu={event.bushoCapacity ?? event.capacity}
                                  >
                                    {event.capacity}
                                  </span>
                                </div>
                              )}
                              <div class="detail-row">
                                <span class="detail-label" data-busho-ja="会場" data-busho-bu="御陣所">会場</span>
                                <span class="detail-value">
                                  <a
                                    href={event.venueUrl}
                                    target="_blank"
                                    rel="noopener noreferrer"
                                    class="venue-link"
                                    data-busho-ja={event.venue}
                                    data-busho-bu={event.bushoVenue ?? event.venue}
                                  >
                                    {event.venue}
                                  </a>
                                </span>
                              </div>
                            </div>
                          </div>

                          <div class="event-action">
                            <a href={event.registrationUrl} target="_blank" rel="noopener noreferrer" class="registration-button">
                              <span
                                data-busho-ja={event.registrationLabel}
                                data-busho-bu={event.bushoRegistrationLabel ?? event.registrationLabel}
                              >
                                {event.registrationLabel}
                              </span>
                            </a>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                ) : (
                  <div class="day-card">
                    <div class="no-events">
                      <BushoText
                        as="p"
                        ja="イベントはありません。関連イベントが決まり次第、このページでお知らせします。"
                        bu="只今、陣中催事の触れはござらぬ。新たな催し定まり次第、この場にて告げ知らせ候。"
                      />
                    </div>
                  </div>
                )}
              </div>
            ))}
          </div>
        ) : (
          <BushoText
            as="p"
            class="text-center text-gray-500"
            ja="現在、イベント情報はありません。"
            bu="只今、陣中催事の報せはござらぬ。"
          />
        )}
      </div>
    </div>
  </div>
</Layout>

<style>
  .day-nav {
    display: flex;
    justify-content: center;
    gap: 2rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .day-nav-link {
    font-weight: bold;
    color: #332F2E;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .day-nav-link:hover {
    opacity: 0.7;
  }

  .day-nav-separator {
    color: #ccc;
  }

  .days-container {
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  .day-section {
  }

  .day-header {
    padding: 1rem 0;
    display: flex;
    align-items: center;
    gap: 1rem;
  }

  .day-card {
    border: 1px solid #e5e7eb;
    border-radius: 12px;
    overflow: hidden;
  }

  .day-label {
    font-size: 1.5rem;
    font-weight: bold;
    color: #332F2E;
  }

  @media (min-width: 768px) {
    .day-label {
      font-size: 2rem;
    }
  }

  .day-date {
    font-size: 1rem;
    color: #332F2E;
  }

  .day-date {
    font-size: 1.5rem;
    color: #332F2E;
  }

  .events-list {
    display: flex;
    flex-direction: column;
  }

  .event-card {
    display: flex;
    flex-direction: column;
    padding: 1.5rem;
    background: white;
    border-bottom: 1px solid #e5e7eb;
  }

  .event-card:last-child {
    border-bottom: none;
  }

  @media (min-width: 768px) {
    .event-card {
      display: grid;
      grid-template-columns: 35% 1fr auto;
      gap: 1.5rem;
      align-items: center;
      padding: 1.5rem 2rem;
    }
  }

  .event-thumbnail {
    width: 100%;
    margin: 0 auto 1rem;
  }

  @media (min-width: 768px) {
    .event-thumbnail {
      width: 100%;
      margin: 0;
    }
  }

  .event-thumbnail img {
    width: 100%;
    height: auto;
    border-radius: 8px;
    border: 1px solid #e5e7eb;
  }

  .event-info {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .event-title {
    font-size: 1.25rem;
    font-weight: bold;
    color: #332F2E;
    margin: 0;
  }

  @media (min-width: 768px) {
    .event-title {
      font-size: 1.5rem;
    }
  }

  .event-organizer {
    font-size: 1rem;
    color: #666;
    margin: 0 0 0.5rem 0;
  }

  .event-description {
    color: #332F2E;
    font-size: 0.95rem;
    line-height: 1.7;
    margin: 0 0 0.5rem 0;
  }

  .event-details {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    margin-bottom: 1rem;
  }

  @media (min-width: 768px) {
    .event-details {
      margin-bottom: 0;
    }
  }

  .detail-row {
    display: flex;
    gap: 0.75rem;
    font-size: 1rem;
  }

  .detail-label {
    color: #666;
    min-width: 50px;
  }

  .detail-value {
    color: #332F2E;
  }

  .venue-link {
    color: #0e0aca;
    text-decoration: underline;
    transition: opacity 0.2s;
  }

  .venue-link:hover {
    opacity: 0.7;
  }

  .event-action {
    display: flex;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .event-action {
      justify-content: flex-end;
    }
  }

  .registration-button {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: transparent;
    color: #332F2E;
    border: 2px solid #332F2E;
    border-radius: 9999px;
    font-weight: bold;
    text-decoration: none;
    transition: all 0.2s;
  }

  .registration-button:hover {
    background: white;
    opacity: 0.7;
  }

  .no-events {
    padding: 2rem;
    text-align: center;
    color: #666;
    background: #f9fafb;
  }

  .no-events p {
    margin: 0;
  }
</style>
