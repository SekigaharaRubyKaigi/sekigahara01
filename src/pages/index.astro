---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import logoImage from '../assets/main-visual.svg';
import akaKabuto from '../assets/aka-kabutosan.svg';
import aoKabuto from '../assets/ao-kabutosan.svg';
import pinBlack from '../assets/pin_black.svg';
import githubIcon from '../assets/github-logo.svg';
import xIcon from '../assets/x-logo.svg';
import LinkButton from '../components/LinkButton.astro';
import BushoText from '../components/BushoText.astro';
import LanguageToggle from '../components/LanguageToggle.astro';

// ▼ ニュース機能の読み込み
import { getCollection } from 'astro:content';

// データを取得
let latestNews = [];
try {
  const allNews = await getCollection('news');
  const sortedNews = allNews.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
  latestNews = await Promise.all(
    sortedNews.slice(0, 3).map(async (post) => ({
      ...post,
      Content: (await post.render()).Content,
    }))
  );
} catch (e) {
  console.error("News loading failed:", e);
}

// 日付フォーマット関数
const formatDate = (date) => {
  if (!date) return '';
  return date.toLocaleDateString('ja-JP', {
    year: 'numeric',
    month: 'long',
    day: 'numeric'
  });
};
---

<Layout title="関ケ原Ruby会議01">
  <div class="w-full pb-1">

    <div class="text-center pt-6 pb-0 md:pt-10 md:pb-0">
      <div class="mx-auto w-80 md:w-96 mb-6 relative">
        <Image 
          src={logoImage} 
          alt="関ケ原Ruby会議01メインビジュアル" 
          class="w-full h-auto object-contain" 
        />
      </div>

      <h1 class="mb-4 flex justify-center">
        <img src="/sekigahara01/logo.svg" alt="関ケ原Ruby会議01" class="w-full max-w-xl md:max-w-2xl h-auto" />
      </h1>

      <p class="text-2xl md:text-3xl font-bold mb-6 text-[#332F2E]">
        2026年5月30日(土)
      </p>

      <p class="text-base md:text-xl text-[#332F2E] mb-8">
        <BushoText ja="会場:" bu="御陣所:" /> <a href="https://www.town.sekigahara.gifu.jp/2568.htm"
          target="_blank"
          rel="noopener noreferrer"
          class="hover:opacity-70 transition-opacity underline"
        >関ケ原ふれあいセンター</a>
      </p>

      <div class="flex flex-col md:flex-row gap-4 justify-center items-center">
        <div class="w-[280px] h-[52px] flex items-center justify-center">
          <LinkButton href="https://ti.to/sekigahara/01" text="本編参加チケット購入" bushoText="本戦の参陣手形を求む" variant="primary" size="large" />
        </div>
        <div class="w-[280px] h-[52px] flex items-center justify-center">
          <LinkButton href="https://sponsorships.sekigahara01.saltandmayo.net/conferences/sekigahara01/sponsorship/new" text="スポンサー申し込み" bushoText="御支援に名乗り出で候" variant="primary" size="large" />
        </div>
      </div>

      <div class="mt-8 flex justify-center">
        <LanguageToggle />
      </div>
    </div>

    <section id="about" class="max-w-screen-lg mx-auto mt-4 md:mt-4 mb-20">
      <div class="bg-white/90 px-4 py-8 md:px-8 md:py-16 lg:px-16 rounded-xl shadow-lg text-[#332F2E]">
        <div class="mb-8">
          <BushoText
            as="h2"
            class="text-3xl md:text-4xl font-bold text-center tracking-wider"
            ja="天下分け目の地域Ruby会議"
            bu="天下分け目の地域Ruby会議に候"
          />
          <div class="h-2 w-16 mx-auto mt-4 bg-gradient-to-r from-[#fc2158] to-[#0e0aca]"></div>
        </div>
        <div class="text-lg leading-loose">
          <BushoText
            as="p"
            ja="関ケ原Ruby会議01は、天下分け目の地「関ケ原」で開催される地域Ruby会議です。"
            bu="関ケ原Ruby会議01は、天下分け目の地「関ケ原」に本陣を構え、Rubyを語らう諸将参集の場に候。"
          />
          <BushoText
            as="p"
            ja="歴史ある古戦場で、新たなRubyの歴史を刻みましょう。"
            bu="いにしえの兵どもが夢の跡にて、いざ新たなるRubyの軍記を刻まん。"
          />
        </div>
      </div>
    </section>

    <section id="news" class="max-w-screen-lg mx-auto mb-20">
      <div class="bg-white/90 px-4 py-8 md:px-8 md:py-16 lg:px-16 rounded-xl shadow-lg">
        <div class="mb-8">
          <BushoText
            as="h2"
            class="text-3xl md:text-4xl font-bold text-center text-[#332F2E] tracking-wider"
            ja="お知らせ"
            bu="陣触"
          />
          <div class="h-2 w-16 mx-auto mt-4 bg-gradient-to-r from-[#fc2158] to-[#0e0aca]"></div>
        </div>

      <div class="bg-white rounded-xl overflow-hidden">
        {latestNews.length === 0 ? (
          <BushoText as="p" class="p-8 text-center text-gray-500" ja="現在お知らせはありません。" bu="新しき陣触、只今これ無く候。" />
        ) : (
          <div class="divide-y divide-gray-200/50">
            {latestNews.map((post) => {
              return (
                <article class="p-6">
                  <div class="flex flex-col gap-4">
                    <div class="flex flex-col md:flex-row md:items-baseline gap-2 md:gap-6">
                      <time class="font-bold text-gray-600 font-sans min-w-[100px]">
                        {formatDate(post.data.date)}
                      </time>
                      <h3
                        class="flex-grow font-bold text-[#332F2E] text-lg md:text-xl leading-[1.5]"
                        data-busho-ja={post.data.title}
                        data-busho-bu={post.data.bushoTitle ?? post.data.title}
                      >
                        {post.data.title}
                      </h3>
                    </div>
                    <div class="text-[#332F2E] text-base leading-[1.8]">
                      <post.Content />
                    </div>
                  </div>
                </article>
              );
            })}
          </div>
        )}
      </div>

        <div class="mt-6">
          <LinkButton href="/sekigahara01/news" text="もっと見る" bushoText="陣触をさらに改め候" variant="secondary" />
        </div>
      </div>
    </section>

    <section id="taisho" class="max-w-screen-lg mx-auto mb-20">
      <div class="bg-white/90 px-4 py-8 md:px-8 md:py-16 lg:px-16 rounded-xl shadow-lg">
        <div class="mb-8">
          <BushoText
            as="h2"
            class="text-3xl md:text-4xl font-bold text-center text-[#332F2E] tracking-wider"
            ja="大将"
            bu="大将"
          />
          <div class="h-2 w-16 mx-auto mt-4 bg-gradient-to-r from-[#fc2158] to-[#0e0aca]"></div>
        </div>

        <div class="flex justify-center mb-8">
          <img
            src="/sekigahara01/taisho.jpg"
            alt="大将"
            class="w-full max-w-2xl rounded-lg shadow-md"
          />
        </div>

        <div class="grid grid-cols-2 gap-4 md:gap-8">
          <!-- 東軍大将 -->
          <div class="text-center">
            <div class="mb-3">
              <span class="inline-block px-4 py-1 rounded-full text-sm font-bold" style="background-color: rgba(240, 38, 38, 0.1); color: #F02626;">
                東軍大将
              </span>
            </div>
            <BushoText
              as="h3"
              class="text-xl md:text-3xl font-bold text-[#332F2E] mb-4 leading-snug"
              ja="笹田 耕一"
              bu="源笹田武蔵守八有丸耕一"
            />
            <div class="flex items-center justify-center gap-2">
              <a href="https://github.com/ko1" target="_blank" rel="noopener noreferrer" class="inline-flex hover:opacity-70 transition-opacity no-underline">
                <Image src={githubIcon} alt="GitHub" class="w-7 h-7" style="width: 28px; height: 28px;" />
              </a>
            </div>
          </div>

          <!-- 西軍大将 -->
          <div class="text-center">
            <div class="mb-3">
              <span class="inline-block px-4 py-1 rounded-full text-sm font-bold" style="background-color: rgba(45, 38, 240, 0.1); color: #2D26F0;">
                西軍大将
              </span>
            </div>
            <BushoText
              as="h3"
              class="text-xl md:text-3xl font-bold text-[#332F2E] mb-4 leading-snug"
              ja="前田 修吾"
              bu="平前田治部少輔齎文吉修吾"
            />
            <div class="flex items-center justify-center gap-4">
              <a href="https://github.com/shugo" target="_blank" rel="noopener noreferrer" class="inline-flex hover:opacity-70 transition-opacity no-underline">
                <Image src={githubIcon} alt="GitHub" class="w-7 h-7" style="width: 28px; height: 28px;" />
              </a>
              <a href="https://x.com/shugomaeda" target="_blank" rel="noopener noreferrer" class="inline-flex hover:opacity-70 transition-opacity no-underline">
                <Image src={xIcon} alt="X" class="w-7 h-7" style="width: 28px; height: 28px;" />
              </a>
            </div>
          </div>
        </div>
      </div>
    </section>

    <div class="flex justify-center items-end gap-12 mt-20 mb-0">
      <div class="sway-animation">
        <Image
          src={akaKabuto}
          alt="あかかぶとさん"
          class="w-24 h-24 md:w-32 md:h-32 lg:w-40 md:h-40"
        />
      </div>
      <div class="sway-animation" style="animation-delay: 0.5s;">
        <Image
          src={aoKabuto}
          alt="あおかぶとさん"
          class="w-24 h-24 md:w-32 md:h-32 lg:w-40 md:h-40"
        />
      </div>
    </div>

  </div>
</Layout>

<style>
  @keyframes sway {
    0%, 100% {
      transform: rotate(-5deg);
    }
    50% {
      transform: rotate(5deg);
    }
  }

  .sway-animation {
    animation: sway 4s ease-in-out infinite;
  }
</style>
