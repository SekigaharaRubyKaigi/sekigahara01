---
import Layout from '../layouts/Layout.astro';
import { parse } from 'yaml';
import fs from 'fs';
import path from 'path';

// YAMLファイルを読み込む
const yamlPath = path.join(process.cwd(), 'src', 'content', 'sponsors.yml');
const yamlContent = fs.readFileSync(yamlPath, 'utf-8');
const data = parse(yamlContent);
const allSponsors = data.sponsors || [];

// 求人情報を持つスポンサーのみをフィルタリング
const jobSponsors = allSponsors.filter(s => s.jobDescription && s.jobUrl);
---

<Layout title="ジョブボード - 関ケ原Ruby会議01" alignTop={true}>
  <div class="w-full py-10">
    <div class="max-w-screen-lg mx-auto">
      <div class="bg-white/90 px-4 py-8 md:px-8 md:py-16 lg:px-16 rounded-xl shadow-lg">
        <div class="mb-12">
          <h1 class="text-3xl md:text-4xl font-bold text-center text-[#332F2E] tracking-wider">
            ジョブボード
          </h1>
          <div class="h-2 w-16 mx-auto mt-4 bg-gradient-to-r from-[#fc2158] to-[#0e0aca]"></div>
        </div>

        {jobSponsors.length > 0 && (
          <div class="grid grid-cols-1 gap-6 md:gap-8">
            {jobSponsors.map((sponsor) => (
              <div class="job-card">
                <div class="flex flex-col md:flex-row items-center md:items-start gap-4 md:gap-6 h-full">
                  <a href={sponsor.jobUrl} target="_blank" rel="noopener noreferrer" class="flex items-center justify-center w-[160px] h-[160px] flex-shrink-0 border border-gray-300 rounded-2xl p-2 bg-white">
                    <img
                      src={sponsor.image}
                      alt={sponsor.name}
                      class="max-h-full max-w-full object-contain"
                    />
                  </a>
                  <div class="flex flex-col flex-grow">
                    <a href={sponsor.jobUrl} target="_blank" rel="noopener noreferrer" class="no-underline">
                      <h2 class="text-xl font-bold text-[#332F2E] mb-2 hover:text-blue-600 transition-colors">
                        {sponsor.name}
                      </h2>
                    </a>
                    <p class="text-gray-700 text-base leading-relaxed mb-4">
                      {sponsor.jobDescription}
                    </p>
                    <div class="mt-auto">
                      <a
                        href={sponsor.jobUrl}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="inline-flex items-center gap-1 text-blue-600 hover:text-blue-800 transition-colors"
                      >
                        採用情報を見る
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                        </svg>
                      </a>
                    </div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        )}

        {jobSponsors.length === 0 && (
          <p class="text-center text-gray-500">
            現在、求人情報はありません。
          </p>
        )}
      </div>
    </div>
  </div>
</Layout>

<style>
  .job-card {
    position: relative;
    background: white;
    padding: 1rem;
    border-radius: 6px;
    box-shadow: 0 1px 3px 0 rgb(0 0 0 / 0.1), 0 1px 2px -1px rgb(0 0 0 / 0.1);
    transition: box-shadow 0.3s ease;
  }

  .job-card:hover {
    box-shadow: 0 4px 6px -1px rgb(0 0 0 / 0.1), 0 2px 4px -2px rgb(0 0 0 / 0.1);
  }

</style>
