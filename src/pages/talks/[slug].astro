---
import Layout from '../../layouts/Layout.astro';
import { parse } from 'yaml';
import fs from 'fs';
import path from 'path';

// YAMLファイルを読み込む
const yamlPath = path.join(process.cwd(), 'src', 'content', 'speakers.yml');
const yamlContent = fs.readFileSync(yamlPath, 'utf-8');
const data = parse(yamlContent);

export function getStaticPaths() {
  const yamlPath = path.join(process.cwd(), 'src', 'content', 'speakers.yml');
  const yamlContent = fs.readFileSync(yamlPath, 'utf-8');
  const data = parse(yamlContent);

  const paths = [];
  ['east', 'west'].forEach(army => {
    (data[army] || []).forEach(speaker => {
      paths.push({
        params: { slug: speaker.githubID },
        props: { speaker, army },
      });
    });
  });
  return paths;
}

const { speaker, army } = Astro.props;
const armyLabel = army === 'east' ? '東軍' : '西軍';
const armyColor = army === 'east' ? '#F02626' : '#2D26F0';
const armyBgColor = army === 'east' ? 'rgba(240, 38, 38, 0.1)' : 'rgba(45, 38, 240, 0.1)';
---

<Layout title={`${speaker.title} - 関ケ原Ruby会議01`} alignTop={true}>
  <div class="w-full py-10">
    <div class="max-w-screen-lg mx-auto">
      <div class="bg-white/90 px-4 py-8 md:px-8 md:py-16 lg:px-16 rounded-xl shadow-lg">
        <!-- 戻るリンク -->
        <a
          href="/sekigahara01/schedule"
          class="inline-flex items-center text-[#332F2E] hover:opacity-70 transition-opacity mb-8 no-underline"
        >
          <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
          </svg>
          スケジュールに戻る
        </a>

        <!-- トークタイトル -->
        <div class="mb-8">
          <span
            class="role-tag inline-block mb-3"
            style={`background-color: ${armyBgColor}; color: ${armyColor};`}
          >
            {armyLabel} {speaker.role}
          </span>
          <h1
            class="text-2xl md:text-3xl font-bold text-[#332F2E] pb-4 border-b-4"
            style={`border-color: ${armyColor};`}
          >
            {speaker.title}
          </h1>
        </div>

        <!-- トーク概要 -->
        <div class="mb-8">
          <div class="text-gray-700 whitespace-pre-wrap" style="line-height: 1.8;">
            {speaker.description}
          </div>
        </div>

        <!-- 登壇者 -->
        <div>
          <div class="flex flex-col md:flex-row gap-6 md:gap-8">
            <!-- アバター -->
            <div class="flex-shrink-0 flex justify-center">
              <img
                src={`https://github.com/${speaker.githubID}.png`}
                alt={speaker.name}
                class="w-[120px] h-[120px] md:w-[150px] md:h-[150px] rounded-lg object-cover border border-gray-200"
              />
            </div>

            <!-- 登壇者情報 -->
            <div class="flex-grow text-center md:text-left">
              <h4 class="text-lg md:text-xl font-bold text-[#332F2E] mb-2">
                {speaker.name}
              </h4>
              <div class="flex gap-3 items-center justify-center md:justify-start mb-2">
                {speaker.githubID && (
                  <a
                    href={`https://github.com/${speaker.githubID}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[#332F2E] hover:opacity-70 transition-opacity"
                  >
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
                    </svg>
                  </a>
                )}
                {speaker.xID && (
                  <a
                    href={`https://x.com/${speaker.xID}`}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-[#332F2E] hover:opacity-70 transition-opacity"
                  >
                    <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                      <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/>
                    </svg>
                  </a>
                )}
              </div>
              {speaker.xID && (
                <a
                  href={`https://x.com/${speaker.xID}`}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-[#332F2E] hover:opacity-70 transition-opacity mb-4 inline-block"
                >
                  @{speaker.xID}
                </a>
              )}
              <p class="text-gray-700 leading-relaxed mt-2">
                {speaker.bio}
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<style>
  .role-tag {
    padding: 0.25rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: bold;
  }
</style>
