---

<Layout title="チーム - 関ケ原Ruby会議01" alignTop={true}>
  <div class="w-full py-10">
    <div class="max-w-screen-lg mx-auto">
      <div class="bg-white/90 px-4 py-8 md:px-8 md:py-16 lg:px-16 rounded-xl shadow-lg">
        <div class="mb-12">
          <BushoText
            as="h1"
            class="text-3xl md:text-4xl font-bold text-center text-[#332F2E] tracking-wider"
            ja="チーム"
            bu="奉行衆"
          />
          <div class="h-2 w-16 mx-auto mt-4 bg-gradient-to-r from-[#fc2158] to-[#0e0aca]"></div>
        </div>

        <div class="mb-8 flex justify-center">
          <LanguageToggle />
        </div>

        <section class="mb-8 md:mb-12">
          <BushoText
            as="h2"
            class="text-xl md:text-2xl font-bold mb-4 md:mb-8 text-[#332F2E]"
            ja="オーガナイザー"
            bu="運営奉行衆"
          />
          <div class="grid grid-cols-2 md:grid-cols-2 lg:grid-cols-3 gap-2 md:gap-6">
            {organizers.map((member) => (
              <Member
                name={member.name}
                bushoName={member.bushoName}
                role={member.role}
                bushoRole={member.bushoRole}
                md5Email={member.md5Email}
                sha256Email={member.sha256Email}
                githubID={member.githubID}
                xID={member.xID}
              />
            ))}
          </div>
        </section>

        <section class="mb-8 md:mb-12">
          <BushoText
            as="h2"
            class="text-xl md:text-2xl font-bold mb-4 md:mb-8 text-[#332F2E]"
            ja="サポート"
            bu="御後援衆"
          />
          <div class="grid grid-cols-2 md:grid-cols-2 lg:grid-cols-3 gap-2 md:gap-6">
            {supporters.map((member) => (
              <Member
                name={member.name}
                role={member.role}
                imageUrl={member.imageUrl}
                website={member.website}
              />
            ))}
          </div>
        </section>
      </div>
    </div>
  </div>
</Layout>
